# ==== Alpine Japanese Language Support ====
ARG BASE_IMAGE=oaklight/texlive:alpine-base
FROM ${BASE_IMAGE}

# Optional: use a Chinese APK mirror (e.g., mirrors.tuna.tsinghua.edu.cn)
ARG APK_MIRROR
RUN if [ -n "$APK_MIRROR" ]; then \
        sed -i "s|dl-cdn.alpinelinux.org|${APK_MIRROR}|g" /etc/apk/repositories; \
    fi

# Japanese support: luatexja, platex, uplatex, jsclasses, haranoaji fonts
RUN apk add --no-cache \
        texmf-dist-langjapanese \
        texmf-dist-langcjk
